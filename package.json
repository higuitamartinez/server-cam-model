{
  "name": "document-scanner-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "cert:lan": "node scripts/generate-local-cert.cjs",
    "dev": "tsx watch src/index.ts",
    "dev:lan": "tsx watch src/index.ts",
    "dev:https": "npm run cert:lan && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "start:prod": "node dist/index.js",
    "build": "tsc && node scripts/prepare-build.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "helmet": "^8.0.0",
    "onnxruntime-node": "^1.20.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "selfsigned": "^5.5.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
